<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DustsSpaceLaunchTracker.Views.UpcomingLaunchesPage"
             xmlns:vm="clr-namespace:DustsSpaceLaunchTracker.ViewModels"
             x:DataType="vm:UpcomingLaunchesViewModel"
             Title="Upcoming Launches">

    <Grid RowDefinitions="Auto,Auto,*,Auto"
          ColumnDefinitions="*"
          Padding="16"
          RowSpacing="16">

        <!-- Row 0: Page title -->
        <Label Grid.Row="0"
               Text="Upcoming Launches"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               VerticalOptions="Center" />

        <!-- Row 1: Loading + Error indicators (centered) -->
        <VerticalStackLayout Grid.Row="1"
                             Spacing="12"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="DodgerBlue"
                               HeightRequest="48"
                               WidthRequest="48" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   FontSize="16"
                   HorizontalTextAlignment="Center"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}" />
        </VerticalStackLayout>

        <!-- Row 2 (*): Main content – RefreshView + CollectionView takes remaining space -->
        <RefreshView Grid.Row="2"
                     Command="{Binding LoadLaunchesCommand}"
                     IsRefreshing="{Binding IsLoading}">

            <CollectionView ItemsSource="{Binding Launches}"
                            EmptyView="No upcoming launches scheduled at the moment…"
                            EmptyViewTemplate="{StaticResource EmptyViewTemplate}"
                VerticalScrollBarVisibility="Always">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <!-- Your card goes here – simple version for now -->
                        <Border Stroke="LightGray"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="16"
                                Margin="0,8"
                                BackgroundColor="White"
                                Shadow="True">

                            <VerticalStackLayout Spacing="10">
                                <Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding Rocket?.Configuration?.FullName, StringFormat='{0}', FallbackValue='Unknown rocket'}"
                                       FontSize="16"
                                       TextColor="Gray" />

                                <Label Text="{Binding Net, StringFormat='NET: {0:yyyy-MM-dd HH:mm UTC}', FallbackValue='NET: TBD'}"
                                       FontSize="14"
                                       TextColor="DarkSlateGray" />
                                <Label Text="{Binding Status.Name, StringFormat='{0}', FallbackValue='Unknown status'}"
                                       FontSize="14"
                                       TextColor="{Binding Status, Converter={StaticResource StatusToColorConverter}, TargetNullValue='Gray', FallbackValue='Gray'}" />

                                <!-- Add more fields later: probability, pad, image, etc. -->
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Row 3: Optional footer / last updated info (can be empty for now) -->
        <Label Grid.Row="3"
               Text="Data from TheSpaceDevs API"
               FontSize="12"
               TextColor="Gray"
               HorizontalOptions="Center"
               VerticalOptions="End" />

    </Grid>
</ContentPage>